# Runtime API connection. Use the Supabase pooler URL with Prisma pooler compatibility enabled.
DATABASE_URL="postgresql://postgres.icdctguhkudbatmobuli:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"

# Prisma migration/deploy commands should use Supabase's direct database connection when available.
# Keep this out of runtime code and never commit real credentials.
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.icdctguhkudbatmobuli.supabase.co:5432/postgres"

JWT_SECRET="replace_with_a_long_random_secret"
WEBHOOK_SECRET="replace_with_a_long_random_webhook_secret"
PAYSTACK_SECRET_KEY="sk_test_replace_with_your_paystack_secret_key"
PAYSTACK_PUBLIC_KEY="pk_test_replace_with_your_paystack_public_key"
PAYSTACK_CALLBACK_URL="http://localhost:5173/payment/callback"
FREE_VERIFIED_SELLER_ADS="false"
FRONTEND_URL="https://qwik.ng"
APP_ORIGINS="http://localhost:5173,https://your-frontend.vercel.app"
SOCKET_ORIGINS="http://localhost:5173,https://your-frontend.vercel.app"
PUBLIC_URL="https://api.your-domain.com"
BACKEND_URL="https://api.your-domain.com"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Qwik.ng <no-reply@mail.qwik.ng>"
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace_with_your_upstash_redis_rest_token"
PORT=4000
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_FOLDER="qwik/ads"

# Google Identity Services OAuth 2.0 Web Client ID. REQUIRED to enable Google sign-in.
# Obtain from Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs.
# Must match VITE_GOOGLE_CLIENT_ID set in the frontend. When unset, POST /api/auth/google
# returns HTTP 503 with message "Google sign-in is not configured" and the frontend
# button stays in a disabled "Coming soon" state. Email/password auth is unaffected.
GOOGLE_CLIENT_ID=""

# GA4 reporting sync for admin analytics. Keep credentials backend-only.
GA4_PROPERTY_ID=""
GA4_REPORTING_ENABLED="false"
GA4_TIMEOUT_MS="4000"
# Single-line JSON string for service account credentials (Render secret env var).
GOOGLE_SERVICE_ACCOUNT_JSON="{}"
# Optional alternative when mounting a credentials file instead of JSON string.
GOOGLE_APPLICATION_CREDENTIALS=""
