generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AdStatus {
  ACTIVE
  SOLD
  DRAFT
  ARCHIVED
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum VerificationType {
  BUSINESS
}

enum VerificationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
}

enum VerificationPaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
}

enum PaymentPurpose {
  VERIFICATION
  AD_PROMOTION
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  passwordHash    String?
  fullName        String
  phone           String?
  location        String?
  locationState   String?
  locationArea    String?
  googleId        String?      @unique
  authProvider    String?
  role            UserRole     @default(USER)
  status          UserStatus   @default(ACTIVE)
  bannedAt        DateTime?
  banReason       String?
  termsAcceptedAt DateTime?
  privacyAcceptedAt DateTime?
  termsVersion    String?
  privacyVersion  String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  profile         UserProfile?
  ads             Ad[]
  savedAds        SavedAd[]
  reviews         Review[]
  reports         Report[]
  conversationParticipants ConversationParticipant[]
  messagesSent    Message[]
  notifications   Notification[]
  notificationSettings NotificationSettings?
  verificationApplications VerificationApplication[] @relation("VerificationApplicant")
  reviewedVerifications VerificationApplication[] @relation("VerificationReviewer")
  payments        PaymentTransaction[]
  adminAuditLogs  AdminAuditLog[] @relation("AdminAuditLogs")
  following       Follow[] @relation("UserFollowing")
  followers       Follow[] @relation("UserFollowers")
  resetToken      String?
  resetTokenExpAt DateTime?
  emailVerifiedAt DateTime?
  emailVerificationOtpHash String?
  emailVerificationOtpExpiresAt DateTime?
  emailVerificationOtpAttempts Int @default(0)
  emailVerificationOtpLastSentAt DateTime?
  emailVerificationOtpLockedUntil DateTime?

  @@index([locationState])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?
  avatarUrl   String?
  preferences Json?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  parentId  String?
  createdAt DateTime @default(now())
  parent    Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryHierarchy")
  ads       Ad[]

  @@index([parentId])
}

model Ad {
  id              String    @id @default(cuid())
  userId          String
  categoryId      String
  title           String
  description     String
  price           Float
  location        String
  locationState   String?
  locationArea    String?
  brand           String?
  model           String?
  condition       String?
  specifications  Json?
  status          AdStatus  @default(ACTIVE)
  isPromoted      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category  @relation(fields: [categoryId], references: [id])
  images          AdImage[]
  savedBy         SavedAd[]
  reviews         Review[]
  reports         Report[]
  conversations   Conversation[]
  payments        PaymentTransaction[]

  @@index([categoryId])
  @@index([location])
  @@index([locationState])
  @@index([locationArea])
  @@index([createdAt])
  @@index([status])
}

model Conversation {
  id           String                    @id @default(cuid())
  adId         String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  ad           Ad?                       @relation(fields: [adId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([adId])
  @@index([updatedAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  createdAt      DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  messageType    String       @default("text")
  offerAmount    Int?
  offerStatus    String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([messageType])
}

model AdImage {
  id        String   @id @default(cuid())
  adId      String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId, position])
}

model SavedAd {
  id        String   @id @default(cuid())
  userId    String
  adId      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([userId, adId])
  @@index([userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Review {
  id        String   @id @default(cuid())
  adId      String
  userId    String
  rating    Int      @default(5)
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@index([userId])
}

model Report {
  id        String   @id @default(cuid())
  adId      String
  userId    String
  reason    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([adId])
}

model VerificationApplication {
  id              String                    @id @default(cuid())
  userId          String
  type            VerificationType          @default(BUSINESS)
  status          VerificationStatus        @default(DRAFT)
  businessInfo    Json?
  paymentStatus   VerificationPaymentStatus @default(UNPAID)
  rejectionReason String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewerId      String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  user            User                      @relation("VerificationApplicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewer        User?                     @relation("VerificationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  documents       VerificationDocument[]
  payments        PaymentTransaction[]

  @@unique([userId])
  @@index([status])
  @@index([reviewerId])
}

model VerificationDocument {
  id             String                  @id @default(cuid())
  verificationId String
  url            String
  name           String?
  type           String?
  size           Int?
  purpose        String
  createdAt      DateTime                @default(now())
  verification   VerificationApplication @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
}

model PaymentTransaction {
  id             String                   @id @default(cuid())
  userId         String
  verificationId String?
  adId           String?
  purpose        PaymentPurpose
  provider       String                   @default("manual")
  providerRef    String?                  @unique
  amount         Int
  currency       String                   @default("NGN")
  status         PaymentStatus            @default(PENDING)
  checkoutUrl    String?
  metadata       Json?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verification   VerificationApplication? @relation(fields: [verificationId], references: [id], onDelete: SetNull)
  ad             Ad?                      @relation(fields: [adId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([verificationId])
  @@index([adId])
  @@index([status])
}

model PaymentWebhookEvent {
  id              String   @id @default(cuid())
  provider        String
  providerEventId String   @unique
  payload         Json?
  processedAt     DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  actionUrl String?
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, read])
}

model NotificationSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  emailNotifications  Boolean  @default(true)
  pushNotifications   Boolean  @default(false)
  messageNotifications Boolean @default(true)
  offerNotifications  Boolean  @default(true)
  systemNotifications Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
