generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdStatus {
  ACTIVE
  SOLD
  DRAFT
  ARCHIVED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  passwordHash    String
  fullName        String
  phone           String?
  location        String?
  role            UserRole     @default(USER)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  profile         UserProfile?
  ads             Ad[]
  savedAds        SavedAd[]
  reviews         Review[]
  reports         Report[]
  conversationParticipants ConversationParticipant[]
  messagesSent    Message[]
  resetToken      String?
  resetTokenExpAt DateTime?
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?
  avatarUrl   String?
  preferences Json?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  ads       Ad[]
}

model Ad {
  id              String    @id @default(cuid())
  userId          String
  categoryId      String
  title           String
  description     String
  price           Float
  location        String
  brand           String?
  model           String?
  condition       String?
  specifications  Json?
  status          AdStatus  @default(ACTIVE)
  isPromoted      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category  @relation(fields: [categoryId], references: [id])
  images          AdImage[]
  savedBy         SavedAd[]
  reviews         Review[]
  reports         Report[]
  conversations   Conversation[]

  @@index([categoryId])
  @@index([location])
  @@index([createdAt])
  @@index([status])
}

model Conversation {
  id           String                    @id @default(cuid())
  adId         String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  ad           Ad?                       @relation(fields: [adId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([adId])
  @@index([updatedAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  createdAt      DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model AdImage {
  id        String   @id @default(cuid())
  adId      String
  url       String
  createdAt DateTime @default(now())
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
}

model SavedAd {
  id        String   @id @default(cuid())
  userId    String
  adId      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([userId, adId])
  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  adId      String
  userId    String
  rating    Int      @default(5)
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@index([userId])
}

model Report {
  id        String   @id @default(cuid())
  adId      String
  userId    String
  reason    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([adId])
}
