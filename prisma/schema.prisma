generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdStatus {
  ACTIVE
  SOLD
  DRAFT
  ARCHIVED
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  passwordHash    String
  fullName        String
  phone           String?
  location        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  profile         UserProfile?
  ads             Ad[]
  savedAds        SavedAd[]
  resetToken      String?
  resetTokenExpAt DateTime?
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?
  avatarUrl   String?
  preferences Json?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  ads       Ad[]
}

model Ad {
  id          String    @id @default(cuid())
  userId      String
  categoryId  String
  title       String
  description String
  price       Float
  location    String
  status      AdStatus  @default(ACTIVE)
  isPromoted  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id])
  images      AdImage[]
  savedBy     SavedAd[]

  @@index([categoryId])
  @@index([location])
  @@index([createdAt])
  @@index([status])
}

model AdImage {
  id        String   @id @default(cuid())
  adId      String
  url       String
  createdAt DateTime @default(now())
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
}

model SavedAd {
  id        String   @id @default(cuid())
  userId    String
  adId      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([userId, adId])
  @@index([userId])
}
